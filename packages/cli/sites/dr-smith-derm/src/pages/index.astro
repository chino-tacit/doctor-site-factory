---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TeamGrid from '../components/TeamGrid.astro';
import { getCollection } from 'astro:content';

const specialtyConfig = (await getCollection('specialtyConfig'))[0];
const services = await getCollection('services');
const team = await getCollection('team');

const featuredServices = services
  .filter(s => s.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const hero = specialtyConfig.data.hero;
const theme = specialtyConfig.data.theme;
---

<Layout title={specialtyConfig.data.seo.title} description={specialtyConfig.data.seo.description}>
  <Hero
    headline={hero.headline}
    subheadline={hero.subheadline}
    ctaText={hero.ctaText}
    ctaLink={hero.ctaLink}
    backgroundImage={hero.backgroundImage}
    themeColor={theme.primaryColor}
  />

  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Our Services</h2>
        <p class="text-gray-600 mt-3 max-w-2xl mx-auto">Comprehensive dermatology care tailored to your needs</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredServices.map(service => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            slug={service.data.slug}
            featured={service.data.featured}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services" class="inline-block text-primary font-semibold hover:underline">View All Services &rarr;</a>
      </div>
    </div>
  </section>

  <TeamGrid team={team.map(t => t.data)} />

  <section class="py-16 bg-primary text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Schedule Your Visit?</h2>
      <p class="text-primary-100 mb-8 text-lg">Same-day appointments available. We accept most major insurance plans.</p>
      <a href="/contact" class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors">
        Book Appointment
      </a>
    </div>
  </section>
</Layout>