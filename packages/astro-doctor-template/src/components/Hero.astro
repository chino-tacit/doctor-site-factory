---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaLink: string;
  backgroundImage?: string;
  themeColor?: string;
}

const { headline, subheadline, ctaText, ctaLink, backgroundImage, themeColor = '#2E8B57' } = Astro.props;
// Use BASE_URL for correct asset paths with base config
const baseUrl = import.meta.env.BASE_URL || '/';
const style = backgroundImage
  ? `background-image: url('${baseUrl}${backgroundImage.replace(/^\//, '')}');`
  : `background-color: ${themeColor};`;
---

<section class="relative min-h-screen flex items-center justify-center" style={style}>
  <div class="absolute inset-0 bg-black/40" />
  <div class="relative max-w-4xl mx-auto px-6 text-center text-white">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">{headline}</h1>
    <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto">{subheadline}</p>
    <a
      href={ctaLink}
      class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors"
    >
      {ctaText}
    </a>
  </div>
</section>

<style is:global>
  .font-body { font-family: var(--font-body, 'Inter', sans-serif); }
</style>