---
interface Props {
  team: Array<{
    slug: string;
    name: string;
    title: string;
    bio: string;
    photo?: string;
    credentials?: string[];
  }>;
}

const { team } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/';
---

<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-12">Our Team</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {team.map((member) => (
        <article class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 rounded-full overflow-hidden bg-gray-100">
            {member.photo ? (
              <img src={`${baseUrl}${member.photo.replace(/^\//, '')}`} alt={member.name} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-400 text-4xl font-bold">
                {member.name.split(' ').map(n => n[0]).join('')}
              </div>
            )}
          </div>
          <h3 class="text-xl font-semibold text-gray-900">{member.name}</h3>
          {member.credentials && member.credentials.length > 0 && (
            <p class="text-primary text-sm font-medium mt-1">{member.credentials.join(', ')}</p>
          )}
          <p class="text-gray-600 mt-2">{member.title}</p>
          <p class="text-gray-500 text-sm mt-3 line-clamp-3">{member.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>