---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.jsx';
import { getCollection } from 'astro:content';

const specialtyConfig = (await getCollection('specialtyConfig'))[0];
const clinic = specialtyConfig.data.clinic;
---

<Layout title="Contact Us" description={specialtyConfig.data.seo.description}>
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Contact Us</h1>
          <p class="text-gray-600 mb-8">Have questions? We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>

          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-gray-900">Address</h3>
              <p class="text-gray-600">{clinic.address}</p>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Phone</h3>
              <a href={`tel:${clinic.phone}`} class="text-gray-600 hover:text-primary transition-colors">{clinic.phone}</a>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Email</h3>
              <a href={`mailto:${clinic.email}`} class="text-gray-600 hover:text-primary transition-colors">{clinic.email}</a>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Hours</h3>
              <dl class="text-gray-600 space-y-1 mt-2">
                {clinic.hours.map(h => (
                  <div key={h.day} class="flex justify-between">
                    <dt>{h.day}</dt>
                    <dd>{h.closed ? 'Closed' : `${h.open} - ${h.close}`}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-8 rounded-xl">
          <ContactForm
            client:visible
            clinicEmail={clinic.email}
            clinicName={clinic.name}
          />
        </div>
      </div>
    </div>
  </section>

  {clinic.mapsUrl && (
    <section class="py-16 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-center text-gray-900 mb-8">Find Us</h2>
        <div class="aspect-video w-full rounded-xl overflow-hidden">
          <iframe
            src={clinic.mapsUrl + '&output=embed'}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </section>
  )}
</Layout>