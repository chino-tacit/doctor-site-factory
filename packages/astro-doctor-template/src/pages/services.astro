---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const specialtyConfig = (await getCollection('specialtyConfig'))[0];
const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);
const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title="Our Services" description={specialtyConfig.data.seo.description}>
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Our Services</h1>
        <p class="text-gray-600 mt-3 max-w-2xl mx-auto">Comprehensive care for all your dermatology needs</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedServices.map(service => (
          <ServiceCard
            title={service.data.title}
            description={service.data.description}
            slug={service.slug}
            featured={service.data.featured}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>