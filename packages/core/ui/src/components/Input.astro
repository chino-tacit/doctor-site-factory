---
interface Props {
  label?: string;
  type?: 'text' | 'email' | 'tel' | 'password';
  placeholder?: string;
  value?: string;
  name?: string;
  class?: string;
  error?: string;
  required?: boolean;
  disabled?: boolean;
}

const { label, type = 'text', placeholder, value, name, class: className, error, required, disabled } = Astro.props;
const inputId = name ? `input-${name}` : `input-${Math.random().toString(36).slice(2)}`;

const baseStyles = 'w-full px-4 py-2 rounded-lg border bg-white transition-colors focus:ring-2 focus:ring-primary focus:border-primary disabled:bg-gray-50';
const errorStyles = error ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:border-primary';
const classes = `${baseStyles} ${errorStyles} ${className || ''}`;
---

<div class="space-y-1.5">
  {label && <label for={inputId} class="block text-sm font-medium text-gray-700">{label}</label>}
  <input
    id={inputId}
    type={type}
    placeholder={placeholder}
    value={value}
    name={name}
    class={classes}
    required={required}
    disabled={disabled}
    aria-invalid={error ? 'true' : 'false'}
    aria-describedby={error ? `${inputId}-error` : undefined}
  />
  {error && <p id={`${inputId}-error`} class="text-sm text-red-600" role="alert">{error}</p>}
</div>